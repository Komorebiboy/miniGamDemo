/* 命运赌局 - Boss组件样式 */

.boss-component {
  position: relative;
  padding: 30rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, rgba(26, 26, 36, 0.9) 0%, rgba(10, 10, 15, 0.95) 100%);
  border: 2rpx solid var(--color-neon-purple);
  box-shadow: 0 0 30rpx rgba(138, 43, 226, 0.3);
  overflow: hidden;
}

/* ==================== 背景特效 ==================== */
.boss-bg-effects {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.bg-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(138, 43, 226, 0.1) 0%, transparent 50%);
  animation: glowPulse 3s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

.bg-particles {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.particle {
  position: absolute;
  width: 4rpx;
  height: 4rpx;
  background: var(--color-neon-purple);
  border-radius: 50%;
  box-shadow: 0 0 10rpx var(--color-neon-purple);
  animation: particleFloat 4s ease-in-out infinite;
}

.p1 { top: 20%; left: 20%; animation-delay: 0s; }
.p2 { top: 40%; right: 30%; animation-delay: 1s; }
.p3 { bottom: 30%; left: 40%; animation-delay: 2s; }
.p4 { top: 60%; left: 60%; animation-delay: 1.5s; }
.p5 { bottom: 20%; right: 20%; animation-delay: 0.5s; }

@keyframes particleFloat {
  0%, 100% {
    transform: translateY(0) scale(1);
    opacity: 0.3;
  }
  50% {
    transform: translateY(-20rpx) scale(1.2);
    opacity: 0.8;
  }
}

/* ==================== Boss主体 ==================== */
.boss-body {
  display: flex;
  align-items: center;
  gap: 30rpx;
  position: relative;
  z-index: 2;
}

/* ==================== Boss头像 ==================== */
.boss-avatar-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
}

.boss-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #8A2BE2, #4B0082);
  border: 4rpx solid var(--color-neon-purple);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 30rpx rgba(138, 43, 226, 0.5);
  position: relative;
  overflow: hidden;
}

.boss-avatar::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  animation: avatarShine 3s ease-in-out infinite;
}

@keyframes avatarShine {
  0% { transform: translateX(-100%) rotate(45deg); }
  100% { transform: translateX(100%) rotate(45deg); }
}

.avatar-icon {
  font-size: 60rpx;
  z-index: 2;
}

/* 激怒状态 */
.enraged {
  animation: enragedPulse 1s ease-in-out infinite;
  border-color: var(--color-crazy-red);
  box-shadow: 0 0 40rpx rgba(255, 46, 99, 0.6);
}

@keyframes enragedPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* ==================== 阶段指示器 ==================== */
.phase-indicator {
  display: flex;
  gap: 8rpx;
}

.phase-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(138, 43, 226, 0.3);
  border: 1rpx solid var(--color-neon-purple);
  transition: all 0.3s ease;
}

.phase-dot.active {
  background: var(--color-neon-purple);
  box-shadow: 0 0 10rpx rgba(138, 43, 226, 0.8);
}

/* ==================== Boss信息 ==================== */
.boss-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.boss-name-section {
  display: flex;
  flex-direction: column;
}

.boss-name {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 0 10rpx rgba(138, 43, 226, 0.5);
}

.boss-title {
  font-size: 22rpx;
  color: var(--color-neon-purple);
  text-shadow: 0 0 5rpx rgba(138, 43, 226, 0.3);
}

/* ==================== 血条 ==================== */
.boss-health-bar {
  position: relative;
  width: 100%;
}

.health-bg {
  height: 24rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid rgba(138, 43, 226, 0.3);
}

.health-fill {
  height: 100%;
  background: linear-gradient(90deg, #4B0082 0%, #8A2BE2 50%, #4B0082 100%);
  border-radius: 12rpx;
  transition: width 0.5s ease;
  box-shadow: 0 0 10rpx rgba(138, 43, 226, 0.5);
}

.health-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 18rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 0 4rpx rgba(0, 0, 0, 1);
}

/* ==================== 护盾 ==================== */
.boss-shield {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(0, 212, 255, 0.2);
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.5);
  width: fit-content;
}

.shield-icon {
  font-size: 22rpx;
}

.shield-value {
  font-size: 22rpx;
  color: #00d4ff;
  font-weight: bold;
}

/* ==================== 效果标签 ==================== */
.boss-effects {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.effect-tag {
  font-size: 18rpx;
  padding: 6rpx 12rpx;
  background: rgba(138, 43, 226, 0.2);
  border-radius: 10rpx;
  color: var(--color-neon-purple);
  border: 1rpx solid rgba(138, 43, 226, 0.5);
}

/* ==================== 技能提示 ==================== */
.boss-skill-hint {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: linear-gradient(145deg, rgba(26, 26, 36, 0.95) 0%, rgba(10, 10, 15, 0.98) 100%);
  border-radius: 16rpx;
  padding: 15rpx;
  border: 2rpx solid var(--color-crazy-red);
  box-shadow: 0 0 20rpx rgba(255, 46, 99, 0.4);
  z-index: 10;
  animation: skillHintAppear 0.3s ease-out;
}

@keyframes skillHintAppear {
  0% { transform: scale(0) translateY(10rpx); opacity: 0; }
  100% { transform: scale(1) translateY(0); opacity: 1; }
}

.skill-hint-content {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.skill-name {
  font-size: 22rpx;
  font-weight: bold;
  color: var(--color-crazy-red);
}

.skill-desc {
  font-size: 18rpx;
  color: var(--color-light-gray);
}

/* ==================== 阶段转换特效 ==================== */
.phase-transition {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
  animation: phaseTransitionAppear 0.5s ease-out;
}

@keyframes phaseTransitionAppear {
  0% { opacity: 0; }
  100% { opacity: 1; }
}

.transition-content {
  text-align: center;
  padding: 40rpx;
  background: linear-gradient(145deg, rgba(26, 26, 36, 0.95) 0%, rgba(10, 10, 15, 0.98) 100%);
  border-radius: 20rpx;
  border: 2rpx solid var(--color-neon-purple);
  box-shadow: 0 0 40rpx rgba(138, 43, 226, 0.5);
}

.transition-text {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--color-neon-purple);
  display: block;
  margin-bottom: 15rpx;
  text-shadow: 0 0 20rpx rgba(138, 43, 226, 0.8);
  animation: transitionTextPulse 1s ease-in-out infinite;
}

@keyframes transitionTextPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.transition-desc {
  font-size: 24rpx;
  color: var(--color-light-gray);
}

/* ==================== Boss台词 ==================== */
.boss-dialogue {
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 15;
  animation: dialogueAppear 0.3s ease-out;
}

@keyframes dialogueAppear {
  0% { transform: translateX(-50%) translateY(10rpx); opacity: 0; }
  100% { transform: translateX(-50%) translateY(0); opacity: 1; }
}

.dialogue-bubble {
  background: linear-gradient(145deg, rgba(26, 26, 36, 0.95) 0%, rgba(10, 10, 15, 0.98) 100%);
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  border: 2rpx solid var(--color-gold);
  box-shadow: 0 0 20rpx rgba(212, 175, 55, 0.3);
  position: relative;
  min-width: 300rpx;
  text-align: center;
}

.dialogue-bubble::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 10rpx solid var(--color-gold);
}

.dialogue-text {
  font-size: 24rpx;
  color: white;
  font-style: italic;
}

/* ==================== 不同阶段样式 ==================== */
.boss-component.phase-1 {
  border-color: var(--color-neon-purple);
  box-shadow: 0 0 30rpx rgba(138, 43, 226, 0.3);
}

.boss-component.phase-2 {
  border-color: var(--color-crazy-red);
  box-shadow: 0 0 40rpx rgba(255, 46, 99, 0.4);
}

.boss-component.phase-3 {
  border-color: var(--color-gold);
  box-shadow: 0 0 50rpx rgba(212, 175, 55, 0.5);
  animation: phase3Pulse 2s ease-in-out infinite;
}

@keyframes phase3Pulse {
  0%, 100% { box-shadow: 0 0 50rpx rgba(212, 175, 55, 0.5); }
  50% { box-shadow: 0 0 70rpx rgba(212, 175, 55, 0.8); }
}
