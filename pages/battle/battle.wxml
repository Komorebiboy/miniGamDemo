<!-- 命运赌局 - 战斗界面 -->
<view class="battle-container bg-pattern {{screenShake ? 'screen-shake' : ''}} {{flashWhite ? 'flash-white' : ''}}">
  <!-- 顶部信息栏 -->
  <view class="battle-header">
    <view class="header-left">
      <text class="turn-badge">回合 {{turnNumber}}</text>
    </view>
    <view class="header-center">
      <text class="phase-indicator">{{phaseText}}</text>
    </view>
    <view class="header-right">
      <text class="deck-info">牌库: {{deckRemaining}}</text>
    </view>
  </view>

  <!-- 敌人区域 -->
  <view class="enemy-section">
    <!-- Boss/敌人展示 -->
    <view class="enemy-display">
      <view class="enemy-portrait {{isBoss ? 'boss-portrait' : ''}}">
        <text class="enemy-icon">{{enemyIcon}}</text>
      </view>
      <view class="enemy-info">
        <text class="enemy-name">{{enemyName}}</text>
        <text class="enemy-type" wx:if="{{isBoss}}">BOSS</text>
      </view>
    </view>

    <!-- 敌人血条 -->
    <view class="health-bar-container enemy-health">
      <view class="health-bar-bg">
        <view class="health-bar-fill enemy-hp" style="width: {{enemyHpPercent}}%"></view>
      </view>
      <text class="health-text">{{enemyHp}} / {{enemyMaxHp}}</text>
      <view class="shield-display" wx:if="{{enemyShield > 0}}">
        <text class="shield-icon">🛡️</text>
        <text class="shield-value">{{enemyShield}}</text>
      </view>
    </view>

    <!-- 敌人效果 -->
    <view class="effects-container enemy-effects">
      <view class="effect-badge" wx:for="{{enemyEffects}}" wx:key="index">
        <text>{{item}}</text>
      </view>
    </view>

    <!-- 敌人出牌区域 -->
    <view class="enemy-card-area">
      <view class="card-slot enemy-slot">
        <view class="enemy-card-reveal {{enemySelectedCard ? 'revealed' : 'hidden'}}">
          <view class="mini-card {{enemySelectedCard.rarity}}" wx:if="{{enemySelectedCard}}">
            <view class="mini-card-header">
              <text class="mini-card-icon">{{enemySelectedCard.typeIcon}}</text>
              <text class="mini-card-name">{{enemySelectedCard.name}}</text>
            </view>
            <view class="mini-card-stats">
              <text>Roll: {{enemySelectedCard.rollRange.min}}-{{enemySelectedCard.rollRange.max}}</text>
              <text>⚡{{enemySelectedCard.speed}}</text>
            </view>
          </view>
          <view class="card-back-enemy" wx:else>
            <text class="card-back-text">?</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 战斗舞台 -->
  <view class="battle-stage">
    <!-- 骰子动画区域 -->
    <view class="dice-area" wx:if="{{showRollAnimation}}">
      <view class="dice player-dice animate-roll">
        <text class="dice-value">{{displayPlayerRoll}}</text>
      </view>
      <text class="vs-text">VS</text>
      <view class="dice enemy-dice animate-roll">
        <text class="dice-value">{{displayEnemyRoll}}</text>
      </view>
    </view>

    <!-- 结果展示 -->
    <view class="result-area" wx:if="{{showResult}}">
      <text class="result-text {{resultClass}}">{{resultText}}</text>
      <text class="damage-text" wx:if="{{damageDealt > 0}}">-{{damageDealt}} 💀</text>
    </view>

    <!-- 最终数值 -->
    <view class="final-values" wx:if="{{showFinalValues}}">
      <view class="value-box player-value">
        <text class="value-label">你</text>
        <text class="value-number">{{playerFinalValue}}</text>
      </view>
      <view class="value-box enemy-value">
        <text class="value-label">敌</text>
        <text class="value-number">{{enemyFinalValue}}</text>
      </view>
    </view>
  </view>

  <!-- 玩家区域 -->
  <view class="player-section">
    <!-- 玩家出牌区域 -->
    <view class="player-card-area">
      <view class="card-slot player-slot">
        <view class="player-card-display" wx:if="{{playerSelectedCard}}">
          <view class="selected-card-preview {{playerSelectedCard.rarity}}">
            <view class="preview-header">
              <text class="preview-icon">{{playerSelectedCard.typeIcon}}</text>
              <text class="preview-name">{{playerSelectedCard.name}}</text>
            </view>
            <view class="preview-stats">
              <text>Roll: {{playerSelectedCard.rollRange.min}}-{{playerSelectedCard.rollRange.max}}</text>
              <text>⚡{{playerSelectedCard.speed}}</text>
            </view>
          </view>
        </view>
        <view class="card-slot-placeholder" wx:else>
          <text>选择手牌</text>
        </view>
      </view>
    </view>

    <!-- 玩家效果 -->
    <view class="effects-container player-effects">
      <view class="effect-badge" wx:for="{{playerEffects}}" wx:key="index">
        <text>{{item}}</text>
      </view>
    </view>

    <!-- 玩家血条 -->
    <view class="health-bar-container player-health">
      <view class="shield-display" wx:if="{{playerShield > 0}}">
        <text class="shield-icon">🛡️</text>
        <text class="shield-value">{{playerShield}}</text>
      </view>
      <text class="health-text">{{playerHp}} / {{playerMaxHp}}</text>
      <view class="health-bar-bg">
        <view class="health-bar-fill player-hp" style="width: {{playerHpPercent}}%"></view>
      </view>
    </view>

    <!-- 玩家信息 -->
    <view class="player-display">
      <view class="player-info">
        <text class="player-name">{{playerName}}</text>
        <text class="player-class">{{playerClassText}}</text>
      </view>
      <view class="player-portrait">
        <text class="player-icon">{{playerIcon}}</text>
      </view>
    </view>
  </view>

  <!-- 手牌区域 -->
  <view class="hand-section">
    <view class="hand-header">
      <text class="hand-title">手牌 ({{handCards.length}})</text>
      <view class="hand-actions">
        <text class="energy-display">能量: {{playerEnergy}}</text>
      </view>
    </view>
    <scroll-view class="hand-scroll" scroll-x="true">
      <view class="hand-cards">
        <view
          class="hand-card {{item.selected ? 'selected' : ''}} {{item.rarity}} {{item.exhausted ? 'exhausted' : ''}}"
          wx:for="{{handCards}}"
          wx:key="instanceId"
          bindtap="onHandCardTap"
          data-card="{{item}}"
        >
          <view class="hand-card-inner">
            <view class="card-cost-badge">{{item.cost}}</view>
            <view class="card-icon-large">{{item.typeIcon}}</view>
            <text class="card-name-large">{{item.displayName}}</text>
            <view class="card-stats-large">
              <text>{{item.displayRollRange}}</text>
              <text>⚡{{item.displaySpeed}}</text>
            </view>
            <view class="card-effect-preview">
              <text wx:for="{{item.displayEffects}}" wx:key="index">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button 
      class="action-btn primary-btn {{canConfirm ? '' : 'disabled'}}"
      bindtap="onConfirmTap"
      disabled="{{!canConfirm}}"
    >
      确认出牌
    </button>
    <button 
      class="action-btn secondary-btn"
      bindtap="onSkipTap"
      disabled="{{hasConfirmed}}"
    >
      跳过
    </button>
  </view>

  <!-- 战斗结束弹窗 -->
  <view class="modal-overlay" wx:if="{{showBattleEndModal}}">
    <view class="modal-box animate-zoom-in">
      <text class="modal-title">{{battleEndTitle}}</text>
      <text class="modal-description">{{battleEndText}}</text>
      <view class="modal-stats">
        <view class="stat-row">
          <text class="stat-label">回合数</text>
          <text class="stat-value">{{turnNumber}}</text>
        </view>
        <view class="stat-row">
          <text class="stat-label">剩余生命</text>
          <text class="stat-value">{{playerHp}}/{{playerMaxHp}}</text>
        </view>
      </view>
      <view class="modal-actions">
        <button class="modal-btn primary" bindtap="onReturnToMenu">返回</button>
        <button class="modal-btn" bindtap="onRestartBattle">再来</button>
      </view>
    </view>
  </view>
</view>
