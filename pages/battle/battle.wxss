/* 命运赌局 - 战斗界面样式 */

.battle-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #0D0D0D 0%, #1a0a0a 50%, #0D0D0D 100%);
  position: relative;
  overflow: hidden;
}

/* ==================== 顶部信息栏 ==================== */
.battle-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, rgba(26, 26, 36, 0.95) 0%, rgba(18, 18, 26, 0.95) 100%);
  border-bottom: 2rpx solid var(--color-gold);
  box-shadow: 0 0 20rpx rgba(212, 175, 55, 0.2);
}

.turn-badge {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-gold);
  text-shadow: 0 0 10rpx rgba(212, 175, 55, 0.5);
}

.phase-indicator {
  font-size: 24rpx;
  color: var(--color-deep-red);
  text-shadow: 0 0 10rpx rgba(179, 0, 27, 0.5);
  animation: neonPulse 2s ease-in-out infinite;
}

.deck-info {
  font-size: 22rpx;
  color: var(--color-light-gray);
}

/* ==================== 敌人区域 ==================== */
.enemy-section {
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.enemy-display {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 15rpx;
}

.enemy-portrait {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ff3366, #cc0033);
  border: 3rpx solid var(--color-deep-red);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20rpx rgba(255, 0, 64, 0.4);
}

.boss-portrait {
  background: linear-gradient(145deg, #8A2BE2, #4B0082);
  border-color: var(--color-neon-purple);
  box-shadow: 0 0 30rpx rgba(138, 43, 226, 0.6);
  animation: bossGlow 2s ease-in-out infinite;
}

@keyframes bossGlow {
  0%, 100% { box-shadow: 0 0 20rpx rgba(138, 43, 226, 0.4); }
  50% { box-shadow: 0 0 40rpx rgba(138, 43, 226, 0.8); }
}

.enemy-icon {
  font-size: 48rpx;
}

.enemy-info {
  display: flex;
  flex-direction: column;
}

.enemy-name {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.enemy-type {
  font-size: 20rpx;
  color: var(--color-neon-purple);
  text-shadow: 0 0 10rpx rgba(138, 43, 226, 0.5);
}

/* ==================== 血条样式 ==================== */
.health-bar-container {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 10rpx;
}

.health-bar-bg {
  flex: 1;
  height: 20rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 10rpx;
  overflow: hidden;
  border: 1rpx solid rgba(212, 175, 55, 0.3);
}

.health-bar-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.enemy-hp {
  background: linear-gradient(90deg, #990030 0%, #ff0040 50%, #990030 100%);
  box-shadow: 0 0 10rpx rgba(255, 0, 64, 0.5);
}

.player-hp {
  background: linear-gradient(90deg, #B3001B 0%, #D4AF37 50%, #B3001B 100%);
  box-shadow: 0 0 10rpx rgba(212, 175, 55, 0.5);
}

.health-text {
  font-size: 20rpx;
  color: white;
  font-weight: bold;
  min-width: 120rpx;
  text-align: center;
}

.shield-display {
  display: flex;
  align-items: center;
  gap: 5rpx;
  background: rgba(0, 212, 255, 0.2);
  padding: 5rpx 10rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.5);
}

.shield-icon {
  font-size: 20rpx;
}

.shield-value {
  font-size: 20rpx;
  color: #00d4ff;
  font-weight: bold;
}

/* ==================== 效果标签 ==================== */
.effects-container {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.effect-badge {
  font-size: 18rpx;
  padding: 6rpx 12rpx;
  background: rgba(191, 0, 255, 0.2);
  border-radius: 10rpx;
  color: #bf00ff;
  border: 1rpx solid rgba(191, 0, 255, 0.5);
}

/* ==================== 卡牌区域 ==================== */
.enemy-card-area, .player-card-area {
  display: flex;
  justify-content: center;
  margin: 10rpx 0;
}

.card-slot {
  width: 180rpx;
  min-height: 240rpx;
  background: linear-gradient(145deg, #1a1a24 0%, #0D0D0D 100%);
  border-radius: 16rpx;
  border: 2rpx solid var(--color-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20rpx rgba(212, 175, 55, 0.2);
  position: relative;
  overflow: hidden;
}

.enemy-slot {
  border-color: var(--color-deep-red);
  box-shadow: 0 0 20rpx rgba(255, 0, 64, 0.2);
}

.card-back-enemy {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: repeating-linear-gradient(
    45deg,
    #1a1a24,
    #1a1a24 10rpx,
    #2a2a3a 10rpx,
    #2a2a3a 20rpx
  );
}

.card-back-text {
  font-size: 60rpx;
  font-weight: bold;
  color: var(--color-gold);
  text-shadow: 0 0 20rpx rgba(212, 175, 55, 0.5);
}

/* ==================== 迷你卡牌 ==================== */
.mini-card {
  width: 100%;
  padding: 15rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.mini-card-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.mini-card-icon {
  font-size: 28rpx;
}

.mini-card-name {
  font-size: 20rpx;
  font-weight: bold;
  color: white;
}

.mini-card-stats {
  display: flex;
  justify-content: space-between;
  font-size: 18rpx;
  color: var(--color-light-gray);
}

/* ==================== 战斗舞台 ==================== */
.battle-stage {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: radial-gradient(ellipse at center, rgba(26, 26, 36, 0.8) 0%, transparent 70%);
  border-radius: 20rpx;
  margin: 10rpx 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.2);
}

/* ==================== 骰子动画 ==================== */
.dice-area {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.dice {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(145deg, #2a2a3a 0%, #1a1a24 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid var(--color-gold);
  box-shadow: 0 0 30rpx rgba(212, 175, 55, 0.3);
}

.enemy-dice {
  border-color: var(--color-deep-red);
  box-shadow: 0 0 30rpx rgba(255, 0, 64, 0.3);
}

.dice-value {
  font-size: 60rpx;
  font-weight: bold;
  color: var(--color-gold);
  text-shadow: 0 0 20rpx rgba(212, 175, 55, 0.5);
}

.enemy-dice .dice-value {
  color: var(--color-deep-red);
  text-shadow: 0 0 20rpx rgba(255, 0, 64, 0.5);
}

.vs-text {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-gold);
  text-shadow: 0 0 15rpx rgba(212, 175, 55, 0.5);
}

/* ==================== 结果展示 ==================== */
.result-area {
  text-align: center;
  padding: 20rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 20rpx;
  border: 2rpx solid var(--color-gold);
}

.result-text {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.result-text.win {
  color: var(--color-gold);
  text-shadow: 0 0 20rpx rgba(212, 175, 55, 0.8);
}

.result-text.lose {
  color: var(--color-deep-red);
  text-shadow: 0 0 20rpx rgba(255, 0, 64, 0.8);
}

.damage-text {
  font-size: 36rpx;
  color: var(--color-deep-red);
  font-weight: bold;
  text-shadow: 0 0 15rpx rgba(255, 0, 64, 0.5);
}

/* ==================== 最终数值 ==================== */
.final-values {
  display: flex;
  gap: 30rpx;
}

.value-box {
  text-align: center;
  padding: 20rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 16rpx;
  min-width: 120rpx;
}

.value-label {
  font-size: 20rpx;
  color: var(--color-light-gray);
  display: block;
  margin-bottom: 8rpx;
}

.value-number {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--color-gold);
  text-shadow: 0 0 15rpx rgba(212, 175, 55, 0.5);
}

/* ==================== 玩家区域 ==================== */
.player-section {
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.player-display {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 10rpx;
}

.player-portrait {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #D4AF37, #B3001B);
  border: 3rpx solid var(--color-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20rpx rgba(212, 175, 55, 0.4);
}

.player-icon {
  font-size: 40rpx;
}

.player-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.player-name {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
}

.player-class {
  font-size: 20rpx;
  color: var(--color-gold);
}

/* ==================== 手牌区域 ==================== */
.hand-section {
  padding: 20rpx;
  background: linear-gradient(145deg, rgba(26, 26, 36, 0.8) 0%, rgba(10, 10, 15, 0.9) 100%);
  border-top: 2rpx solid rgba(212, 175, 55, 0.3);
}

.hand-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.hand-title {
  font-size: 28rpx;
  color: var(--color-gold);
  font-weight: bold;
}

.energy-display {
  font-size: 22rpx;
  color: var(--color-light-gray);
}

.hand-scroll {
  white-space: nowrap;
}

.hand-cards {
  display: flex;
  gap: 15rpx;
}

.hand-card {
  width: 140rpx;
  height: 200rpx;
  background: linear-gradient(145deg, #2a2a3a 0%, #1a1a24 50%, #12121a 100%);
  border-radius: 12rpx;
  border: 2rpx solid var(--color-dark-gray);
  position: relative;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.hand-card.selected {
  border-color: var(--color-gold);
  box-shadow: 0 0 25rpx rgba(212, 175, 55, 0.5);
  transform: translateY(-10rpx) scale(1.05);
}

.hand-card.exhausted {
  opacity: 0.5;
  filter: grayscale(0.8);
}

.hand-card-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 10rpx;
  position: relative;
}

.card-cost-badge {
  position: absolute;
  top: 5rpx;
  right: 5rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: var(--color-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: bold;
  color: black;
}

.card-icon-large {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.card-name-large {
  font-size: 20rpx;
  font-weight: bold;
  color: white;
  text-align: center;
  margin-bottom: 5rpx;
}

.card-stats-large {
  display: flex;
  justify-content: space-between;
  width: 100%;
  font-size: 18rpx;
  color: var(--color-light-gray);
}

.card-effect-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 5rpx;
}

.card-effect-preview text {
  font-size: 16rpx;
  color: var(--color-gold);
  background: rgba(212, 175, 55, 0.1);
  padding: 2rpx 6rpx;
  border-radius: 6rpx;
  margin: 2rpx 0;
}

/* ==================== 操作按钮 ==================== */
.action-section {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: rgba(0, 0, 0, 0.5);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  letter-spacing: 4rpx;
  transition: all 0.3s ease;
}

.primary-btn {
  background: linear-gradient(145deg, #D4AF37, #B3001B);
  color: white;
  box-shadow: 0 0 20rpx rgba(212, 175, 55, 0.4);
}

.primary-btn.disabled {
  background: linear-gradient(145deg, #374151, #1f2937);
  color: var(--color-gray);
  box-shadow: none;
}

.secondary-btn {
  background: transparent;
  color: var(--color-light-gray);
  border: 2rpx solid var(--color-dark-gray);
}

/* ==================== 选中卡牌预览 ==================== */
.selected-card-preview {
  width: 100%;
  padding: 15rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.preview-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.preview-icon {
  font-size: 28rpx;
}

.preview-name {
  font-size: 20rpx;
  font-weight: bold;
  color: white;
}

.preview-stats {
  display: flex;
  justify-content: space-between;
  font-size: 18rpx;
  color: var(--color-light-gray);
}

.card-slot-placeholder {
  font-size: 24rpx;
  color: var(--color-gray);
}

/* ==================== 弹窗样式 ==================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-box {
  background: linear-gradient(145deg, #1a1a24 0%, #12121a 100%);
  border-radius: 30rpx;
  padding: 50rpx;
  text-align: center;
  border: 2rpx solid var(--color-gold);
  box-shadow: 0 0 40rpx rgba(212, 175, 55, 0.3);
  max-width: 80%;
}

.modal-title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--color-gold);
  display: block;
  margin-bottom: 20rpx;
  text-shadow: 0 0 15rpx rgba(212, 175, 55, 0.5);
}

.modal-description {
  font-size: 28rpx;
  color: var(--color-light-gray);
  display: block;
  margin-bottom: 30rpx;
}

.modal-stats {
  margin-bottom: 30rpx;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(212, 175, 55, 0.2);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-light-gray);
}

.stat-value {
  font-size: 24rpx;
  color: var(--color-gold);
  font-weight: bold;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 35rpx;
  font-size: 24rpx;
  font-weight: bold;
  border: none;
  background: transparent;
  color: var(--color-light-gray);
  border: 2rpx solid var(--color-dark-gray);
}

.modal-btn.primary {
  background: linear-gradient(145deg, #D4AF37, #B3001B);
  color: white;
  border: none;
  box-shadow: 0 0 15rpx rgba(212, 175, 55, 0.3);
}

/* ==================== 屏幕特效 ==================== */
.screen-shake {
  animation: screenShake 0.5s ease-in-out;
}

@keyframes screenShake {
  0%, 100% { transform: translate(0, 0); }
  10% { transform: translate(-10rpx, -10rpx); }
  20% { transform: translate(10rpx, 10rpx); }
  30% { transform: translate(-10rpx, 10rpx); }
  40% { transform: translate(10rpx, -10rpx); }
  50% { transform: translate(-5rpx, 5rpx); }
  60% { transform: translate(5rpx, -5rpx); }
  70% { transform: translate(-5rpx, -5rpx); }
  80% { transform: translate(5rpx, 5rpx); }
  90% { transform: translate(-2rpx, 2rpx); }
}

.flash-white {
  animation: flashWhite 0.3s ease-out;
}

@keyframes flashWhite {
  0% { filter: brightness(1); }
  50% { filter: brightness(3); }
  100% { filter: brightness(1); }
}

/* ==================== 稀有度样式 ==================== */
.rarity-common {
  border-color: #808080;
}

.rarity-uncommon {
  border-color: #00d4ff;
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.3);
}

.rarity-rare {
  border-color: #bf00ff;
  box-shadow: 0 0 10rpx rgba(191, 0, 255, 0.3);
}

.rarity-legendary {
  border-color: var(--color-gold);
  box-shadow: 0 0 15rpx rgba(212, 175, 55, 0.5);
  animation: legendaryGlow 2s ease-in-out infinite;
}

@keyframes legendaryGlow {
  0%, 100% { box-shadow: 0 0 15rpx rgba(212, 175, 55, 0.5); }
  50% { box-shadow: 0 0 25rpx rgba(212, 175, 55, 0.8); }
}
