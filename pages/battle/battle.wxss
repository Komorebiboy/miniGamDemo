/* 战斗页面样式 */

page {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  min-height: 100vh;
  color: #fff;
}

.battle-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 战斗头部 */
.battle-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.turn-info {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffd700;
}

.phase-info {
  font-size: 24rpx;
  color: #a0a0a0;
}

/* 敌人区域 */
.enemy-area {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 实体卡片 */
.entity-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.entity-card.enemy {
  flex: 1;
  margin-right: 20rpx;
}

.entity-card.player {
  flex: 1;
  margin-left: 20rpx;
}

.entity-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin: 0 20rpx;
}

.enemy-avatar {
  background: linear-gradient(145deg, #ff6b6b, #ee5a5a);
  box-shadow: 0 0 20rpx rgba(255, 107, 107, 0.5);
}

.player-avatar {
  background: linear-gradient(145deg, #4ecdc4, #44a08d);
  box-shadow: 0 0 20rpx rgba(78, 205, 196, 0.5);
}

.entity-info {
  flex: 1;
}

.entity-name {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

/* 血条 */
.hp-bar {
  position: relative;
  height: 24rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.hp-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.3s ease;
}

.player-hp {
  background: linear-gradient(90deg, #4ecdc4, #44a08d);
}

.enemy-hp {
  background: linear-gradient(90deg, #ff6b6b, #ee5a5a);
}

.hp-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 16rpx;
  color: #fff;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.8);
}

/* 能量条 */
.energy-bar {
  margin-bottom: 8rpx;
}

.energy-text {
  font-size: 22rpx;
  color: #ffd700;
}

/* 护盾 */
.shield-bar {
  margin-bottom: 8rpx;
}

.shield-text {
  font-size: 22rpx;
  color: #4ecdc4;
}

/* 效果标签 */
.effects-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.effect-tag {
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 215, 0, 0.3);
  border-radius: 8rpx;
  color: #ffd700;
  border: 1rpx solid rgba(255, 215, 0, 0.5);
}

/* 卡牌槽 */
.card-slot {
  width: 160rpx;
  height: 200rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 16rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.card-back {
  width: 100%;
  height: 100%;
  background: linear-gradient(145deg, #2c3e50, #34495e);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-back::after {
  content: '?';
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.3);
}

.card-selected {
  text-align: center;
}

.selected-text {
  font-size: 24rpx;
  color: #ffd700;
  display: block;
  margin-bottom: 10rpx;
}

.card-revealed {
  text-align: center;
  padding: 20rpx;
}

.card-revealed .card-name {
  font-size: 24rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.card-revealed .card-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffd700;
  display: block;
  margin-bottom: 10rpx;
}

.card-revealed .card-detail {
  font-size: 18rpx;
  color: #a0a0a0;
}

.crit-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: #ff4757;
  color: #fff;
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
  animation: pulse 0.5s ease infinite alternate;
}

.dodge-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: #2ed573;
  color: #fff;
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.empty-text {
  font-size: 28rpx;
  color: #606060;
}

/* 战斗舞台 */
.battle-stage {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 20rpx 0;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 20rpx;
  padding: 20rpx;
}

/* Roll点显示 */
.roll-display {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.roll-box {
  text-align: center;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  min-width: 150rpx;
}

.roll-label {
  font-size: 24rpx;
  color: #a0a0a0;
  display: block;
  margin-bottom: 20rpx;
}

.roll-number {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.roll-number.crit {
  color: #ff4757;
  animation: shake 0.5s ease;
}

.roll-number.dodge {
  color: #2ed573;
}

.vs-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffd700;
}

/* 最终值显示 */
.final-values {
  display: flex;
  gap: 40rpx;
  width: 100%;
  justify-content: center;
}

.final-box {
  text-align: center;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  flex: 1;
  max-width: 300rpx;
}

.final-label {
  font-size: 24rpx;
  color: #a0a0a0;
  display: block;
  margin-bottom: 20rpx;
}

.final-number {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
}

.final-number.winner {
  color: #ffd700;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

.value-breakdown {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.value-breakdown text {
  font-size: 20rpx;
  color: #808080;
}

/* 结果显示 */
.result-display {
  text-align: center;
}

.result-text {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.result-text.win {
  color: #2ed573;
}

.result-text.lose {
  color: #ff4757;
}

.result-text.draw {
  color: #ffd700;
}

.damage-text {
  font-size: 32rpx;
  color: #ff4757;
  font-weight: bold;
}

/* 玩家区域 */
.player-area {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 手牌区域 */
.hand-area {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.hand-title {
  font-size: 28rpx;
  color: #a0a0a0;
  display: block;
  margin-bottom: 20rpx;
}

.hand-scroll {
  white-space: nowrap;
}

.hand-cards {
  display: flex;
  gap: 20rpx;
}

.hand-card {
  width: 140rpx;
  height: 200rpx;
  background: linear-gradient(145deg, #2c3e50, #34495e);
  border-radius: 16rpx;
  position: relative;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.hand-card.selected {
  border-color: #ffd700;
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
  transform: translateY(-10rpx);
}

.hand-card.disabled {
  opacity: 0.5;
}

.card-cost {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  width: 36rpx;
  height: 36rpx;
  background: #ffd700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.card-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 40rpx 10rpx 10rpx;
}

.card-type-icon {
  font-size: 36rpx;
  margin-bottom: 10rpx;
}

.card-name {
  font-size: 22rpx;
  text-align: center;
  margin-bottom: 10rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}

.card-base {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffd700;
}

.card-roll {
  font-size: 18rpx;
  color: #a0a0a0;
}

.card-speed {
  font-size: 18rpx;
  color: #4ecdc4;
  margin-top: 5rpx;
}

/* 操作区域 */
.action-area {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.confirm-btn {
  background: linear-gradient(145deg, #4ecdc4, #44a08d);
  color: #fff;
}

.confirm-btn.disabled {
  background: #606060;
  opacity: 0.5;
}

.skip-btn {
  background: rgba(255, 255, 255, 0.1);
  color: #a0a0a0;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

/* 战斗日志 */
.battle-log {
  height: 150rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 16rpx;
  padding: 20rpx;
}

.log-scroll {
  height: 100%;
}

.log-entries {
  display: flex;
  flex-direction: column;
}

.log-entry {
  padding: 8rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.log-entry.damage {
  color: #ff6b6b;
}

.log-entry.heal {
  color: #4ecdc4;
}

.log-entry.effect {
  color: #ffd700;
}

.log-time {
  font-size: 18rpx;
  color: #606060;
  margin-right: 20rpx;
}

.log-text {
  font-size: 22rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: linear-gradient(145deg, #1a1a2e, #16213e);
  border-radius: 30rpx;
  padding: 60rpx;
  text-align: center;
  border: 2rpx solid rgba(255, 215, 0, 0.3);
  max-width: 80%;
}

.modal-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffd700;
  display: block;
  margin-bottom: 30rpx;
}

.modal-text {
  font-size: 28rpx;
  color: #a0a0a0;
  display: block;
  margin-bottom: 40rpx;
}

.modal-stats {
  margin-bottom: 40rpx;
}

.modal-stats text {
  display: block;
  font-size: 24rpx;
  color: #fff;
  margin-bottom: 10rpx;
}

.modal-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(145deg, #4ecdc4, #44a08d);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border: none;
}

.modal-btn.secondary {
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

/* 动画 */
@keyframes pulse {
  from {
    transform: scale(1);
  }
  to {
    transform: scale(1.1);
  }
}

@keyframes shake {
  0%, 100% {
    transform: translateX(0);
  }
  25% {
    transform: translateX(-10rpx);
  }
  75% {
    transform: translateX(10rpx);
  }
}
