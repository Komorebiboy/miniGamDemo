<view class="container">
  <view class="game-header">
    <text class="title">暗黑赌场</text>
    <text class="subtitle">心理博弈 · Roll对撞 · Roguelike</text>
  </view>

  <view class="hero-section">
    <view class="hero-avatar">
      <text class="hero-icon">🎲</text>
    </view>
    <text class="hero-name">{{selectedClass ? selectedClass.name : '选择你的职业'}}</text>
    <view class="hero-stats" wx:if="{{selectedClass}}">
      <text class="stat">HP: {{selectedClass.startingHp}}</text>
      <text class="stat">{{selectedClass.specialMechanic}}</text>
    </view>
  </view>

  <view class="menu-grid">
    <view class="menu-item primary" bindtap="selectClass">
      <view class="menu-icon class-icon">{{selectedClass ? selectedClass.icon : '👤'}}</view>
      <text class="menu-title">{{selectedClass ? '更换职业' : '选择职业'}}</text>
      <text class="menu-desc">{{selectedClass ? selectedClass.name : '赌徒/魔术师/处刑者/狂徒'}}</text>
    </view>

    <view class="menu-item" bindtap="startAdventure">
      <view class="menu-icon adventure">⚔️</view>
      <text class="menu-title">开始冒险</text>
      <text class="menu-desc">进入Roguelike地牢</text>
    </view>

    <view class="menu-item" bindtap="viewCardEncyclopedia">
      <view class="menu-icon encyclopedia">📚</view>
      <text class="menu-title">卡组百科</text>
      <text class="menu-desc">查看职业卡牌与敌人</text>
    </view>

    <view class="menu-item" bindtap="viewAchievements">
      <view class="menu-icon achievement">🏆</view>
      <text class="menu-title">成就</text>
      <text class="menu-desc">查看解锁成就</text>
    </view>

    <view class="menu-item" bindtap="openSettings">
      <view class="menu-icon settings">⚙️</view>
      <text class="menu-title">设置</text>
      <text class="menu-desc">游戏选项</text>
    </view>
  </view>

  <view class="game-info">
    <text class="version">v1.0.0</text>
    <text class="credit">心理博弈Roguelike卡牌</text>
  </view>
</view>
