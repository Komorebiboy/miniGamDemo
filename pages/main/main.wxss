/* 命运赌局 - 主菜单样式 */

.main-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 30rpx 60rpx;
  position: relative;
  background: linear-gradient(180deg, #0D0D0D 0%, #1a0a0a 50%, #0D0D0D 100%);
  overflow: hidden;
}

/* ==================== 浮动扑克牌装饰 ==================== */
.floating-cards {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.floating-card {
  position: absolute;
  font-size: 80rpx;
  opacity: 0.15;
  color: var(--color-gold);
}

.card-1 {
  top: 10%;
  left: 10%;
}

.card-2 {
  top: 15%;
  right: 15%;
  color: var(--color-deep-red);
}

.card-3 {
  bottom: 20%;
  left: 20%;
}

.card-4 {
  bottom: 25%;
  right: 10%;
  color: var(--color-neon-purple);
}

/* ==================== 标题区域 ==================== */
.title-section {
  text-align: center;
  margin-top: 80rpx;
}

.game-title {
  font-size: 72rpx;
  font-weight: bold;
  color: var(--color-gold);
  letter-spacing: 8rpx;
  display: block;
  margin-bottom: 10rpx;
  font-family: 'Georgia', serif;
}

.game-subtitle {
  font-size: 24rpx;
  color: var(--color-light-gray);
  letter-spacing: 12rpx;
  display: block;
}

/* ==================== 职业选择区域 ==================== */
.class-section {
  width: 100%;
  margin-top: 40rpx;
}

.section-title {
  font-size: 32rpx;
  color: var(--color-gold);
  text-align: center;
  display: block;
  margin-bottom: 30rpx;
  letter-spacing: 4rpx;
}

.class-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.class-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #0D0D0D 100%);
  border: 2rpx solid var(--color-dark-gray);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.class-card.selected {
  border-color: var(--color-gold);
  box-shadow: 0 0 30rpx rgba(212, 175, 55, 0.4);
  transform: scale(1.02);
}

.class-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 15rpx;
}

.gambler-icon {
  text-shadow: 0 0 20rpx rgba(212, 175, 55, 0.5);
}

.magician-icon {
  text-shadow: 0 0 20rpx rgba(138, 43, 226, 0.5);
}

.executioner-icon {
  text-shadow: 0 0 20rpx rgba(55, 65, 81, 0.5);
}

.madman-icon {
  text-shadow: 0 0 20rpx rgba(255, 46, 99, 0.5);
}

.class-name {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 8rpx;
}

.class-desc {
  font-size: 22rpx;
  color: var(--color-light-gray);
  display: block;
}

/* 职业边框效果 */
.class-border-gold,
.class-border-purple,
.class-border-steel,
.class-border-red {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 16rpx;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.class-border-gold {
  border: 2rpx solid var(--color-gold);
  box-shadow: inset 0 0 20rpx rgba(212, 175, 55, 0.2);
}

.class-border-purple {
  border: 2rpx solid var(--color-neon-purple);
  box-shadow: inset 0 0 20rpx rgba(138, 43, 226, 0.2);
}

.class-border-steel {
  border: 2rpx solid #475569;
  box-shadow: inset 0 0 20rpx rgba(71, 85, 105, 0.2);
}

.class-border-red {
  border: 2rpx solid var(--color-crazy-red);
  box-shadow: inset 0 0 20rpx rgba(255, 46, 99, 0.2);
}

.class-card.selected .class-border-gold,
.class-card.selected .class-border-purple,
.class-card.selected .class-border-steel,
.class-card.selected .class-border-red {
  opacity: 1;
  animation: glow 2s ease-in-out infinite;
}

/* ==================== 操作按钮区域 ==================== */
.action-section {
  width: 100%;
  margin-top: 40rpx;
}

.start-btn {
  width: 100%;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.start-btn.disabled {
  opacity: 0.5;
  background: linear-gradient(135deg, #374151 0%, #1f2937 100%);
  border-color: var(--color-dark-gray);
}

.secondary-buttons {
  display: flex;
  gap: 16rpx;
}

.secondary-btn {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid var(--color-dark-gray);
  color: var(--color-light-gray);
  font-size: 26rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  transition: all 0.3s ease;
}

.secondary-btn:active {
  background: rgba(255, 255, 255, 0.1);
  border-color: var(--color-gold);
}

/* ==================== 底部装饰 ==================== */
.bottom-decoration {
  width: 100%;
  text-align: center;
  margin-top: 40rpx;
}

.gold-line {
  width: 60%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
  margin: 0 auto 20rpx;
}

.bottom-text {
  font-size: 22rpx;
  color: var(--color-gray);
  letter-spacing: 2rpx;
  opacity: 0.7;
}
